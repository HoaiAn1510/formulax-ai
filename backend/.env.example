# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Port cho backend server (mặc định: 3001)
PORT=3001

# URL frontend (dùng cho CORS + redirect sau khi thanh toán)
FRONTEND_URL=http://localhost:5173

# URL công khai của backend — MoMo IPN cần URL này để gọi ngược về (ngrok/Render)
BACKEND_PUBLIC_URL=http://localhost:3001

# Supabase — service role key (KHÔNG phải anon key), lấy tại Project Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# MoMo — thông tin Sandbox test lấy tại developers.momo.vn, hoặc thông tin thật khi lên production
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
