# Lấy API key tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Port cho backend server (mặc định: 3001)
PORT=3001

# Môi trường chạy. BẮT BUỘC đặt NODE_ENV=production khi deploy (Render → Environment):
# ở production các route DEV (/payos/simulate-success, /payos/payment-status) và trang test
# public/simulate-payment.html bị khoá trả 404. Để trống = development = các route đó mở.
NODE_ENV=development

# URL frontend (dùng cho CORS + redirect sau khi thanh toán)
FRONTEND_URL=http://localhost:5173

# URL công khai của backend — PayOS webhook cần URL này để gọi ngược về (ngrok/Render)
BACKEND_PUBLIC_URL=http://localhost:3001

# Supabase — service role key (KHÔNG phải anon key), lấy tại Project Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PayOS — lấy tại https://payos.vn (mục Kênh thanh toán → Thông tin kết nối)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Khoá bảo vệ route POST /api/payment/payos/simulate-success (test thủ công không cần chuyển khoản thật)
# Chỉ có tác dụng khi NODE_ENV != production. Bỏ trống hoặc xoá dòng này để khoá hẳn route lại.
DEV_SIMULATE_SECRET=your_random_dev_secret
